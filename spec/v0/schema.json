{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bgiesbrecht.github.io/tessera/spec/v0/schema.json",
  "title": "Tessera v0 Policy Schema",
  "description": "Structural validation for Tessera policy documents in JSON-LD form. Validates document shape: required fields, type enums, conditional dependencies. Semantic validation (CURIE resolution, classification existence, references to known purposes, etc.) is the job of SHACL shapes in spec/v0/shapes.ttl — this schema does not duplicate that territory. See technical-design-v0.2.md §4.2 and §7.2 for how this layer fits in the validation pipeline. Three top-level document shapes are accepted: a Policy container (canonical multi-branch form, ADR-014); a single PolicyConstraint (backward-compat single-rule form); and a @graph of PolicyConstraints (legacy multi-branch form, deprecated by ADR-014 but accepted during the v0 lifecycle).",

  "oneOf": [
    { "$ref": "#/$defs/policyDocument" },
    { "$ref": "#/$defs/constraintDocument" },
    { "$ref": "#/$defs/graphDocument" }
  ],

  "$defs": {

    "policyDocument": {
      "title": "Policy container document",
      "description": "A JSON-LD document whose root node is a tessera:Policy — the canonical multi-branch form per ADR-014.",
      "type": "object",
      "required": ["@context", "@type", "policyKind", "appliesTo", "rules"],
      "properties": {
        "@context": { "$ref": "#/$defs/contextRef" },
        "@type":    { "const": "Policy" },
        "@id":      { "type": "string", "minLength": 1 },
        "version":  { "type": "string" },
        "description": { "type": "string" },
        "policyKind": { "$ref": "#/$defs/policyKind" },
        "appliesTo": { "$ref": "#/$defs/resourceSelector" },
        "action":    { "$ref": "#/$defs/action" },
        "rules":     {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/rule" }
        },
        "defaultStrategy": { "$ref": "#/$defs/defaultStrategy" },
        "baselineGroup":   { "type": "string", "minLength": 1 },
        "defaultBranch":   { "$ref": "#/$defs/defaultBranchRule" },
        "capabilityRequirements": { "type": "array", "items": { "type": "string" } },
        "provenance": { "$ref": "#/$defs/provenance" }
      },
      "allOf": [
        {
          "description": "ADR-013: when defaultStrategy is explicit-baseline-group, baselineGroup must be present.",
          "if": {
            "properties": { "defaultStrategy": { "const": "explicit-baseline-group" } },
            "required": ["defaultStrategy"]
          },
          "then": { "required": ["baselineGroup"] }
        },
        {
          "description": "baselineGroup should not appear unless defaultStrategy is explicit-baseline-group.",
          "if": { "required": ["baselineGroup"] },
          "then": {
            "properties": { "defaultStrategy": { "const": "explicit-baseline-group" } },
            "required": ["defaultStrategy"]
          }
        },
        {
          "description": "ADR-014: defaultBranch is required iff defaultStrategy is negated-complement; forbidden otherwise.",
          "if": {
            "properties": { "defaultStrategy": { "const": "negated-complement" } },
            "required": ["defaultStrategy"]
          },
          "then": { "required": ["defaultBranch"] },
          "else": { "not": { "required": ["defaultBranch"] } }
        },
        {
          "description": "ADR-022: per-rule and per-defaultBranch transformation constraints are effect-driven and enforced inside the rule / defaultBranchRule $defs, not at the policy level."
        }
      ]
    },

    "constraintDocument": {
      "title": "Single-constraint document (backward-compat single-rule form)",
      "description": "A JSON-LD document whose root node is a single Tessera policy constraint. Backward-compatible single-rule shape; the canonical multi-branch shape is the Policy container (see policyDocument).",
      "type": "object",
      "required": ["@context", "@type"],
      "properties": {
        "@context": { "$ref": "#/$defs/contextRef" }
      },
      "allOf": [{ "$ref": "#/$defs/policyConstraint" }]
    },

    "graphDocument": {
      "title": "Graph document (legacy multi-branch shape)",
      "description": "A JSON-LD document containing a @graph of one or more Tessera policy constraints. Deprecated for multi-branch policies by ADR-014; the canonical shape is the Policy container. Still accepted during the v0 lifecycle for backward compatibility with policies authored before ADR-014.",
      "type": "object",
      "required": ["@context", "@graph"],
      "properties": {
        "@context": { "$ref": "#/$defs/contextRef" },
        "@graph": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/policyConstraint" }
        }
      }
    },

    "contextRef": {
      "description": "@context must reference the Tessera v0 context document. v0 does not support inlined contexts (ADR-004).",
      "oneOf": [
        { "type": "string", "format": "uri" },
        { "type": "array", "items": { "type": "string", "format": "uri" }, "minItems": 1 }
      ]
    },

    "policyKind": {
      "description": "Discriminator selecting the policy domain inside a Policy container. Determines the legal shape of each rule.",
      "enum": [
        "AccessConstraint",
        "RowVisibilityConstraint",
        "ColumnVisibilityConstraint",
        "DistributionConstraint",
        "tessera:AccessConstraint",
        "tessera:RowVisibilityConstraint",
        "tessera:ColumnVisibilityConstraint",
        "tessera:DistributionConstraint"
      ]
    },

    "rule": {
      "title": "Policy rule",
      "description": "A single rule inside a Policy's `rules` list. Carries the principal-and-condition pair plus the effect for that match. Per ADR-022, the transformation field is required iff effect is transform, regardless of the enclosing policy's kind.",
      "type": "object",
      "required": ["principal", "effect"],
      "properties": {
        "@id":         { "type": "string", "minLength": 1 },
        "principal":   { "$ref": "#/$defs/principalSelector" },
        "condition":   { "$ref": "#/$defs/condition" },
        "effect":      { "$ref": "#/$defs/effect" },
        "transformation": { "$ref": "#/$defs/TransformationInstance" }
      },
      "allOf": [
        {
          "description": "ADR-022: transformation is required iff effect is transform.",
          "if": {
            "properties": { "effect": { "enum": ["transform", "tessera:transform"] } },
            "required": ["effect"]
          },
          "then": { "required": ["transformation"] },
          "else": { "not": { "required": ["transformation"] } }
        }
      ]
    },

    "defaultBranchRule": {
      "title": "Default-branch rule",
      "description": "The default branch under defaultStrategy: negated-complement. A slimmer rule with no principal selector (it applies to principals matching no other rule). Per ADR-022, transformation is required iff effect is transform.",
      "type": "object",
      "required": ["effect"],
      "properties": {
        "condition":      { "$ref": "#/$defs/condition" },
        "effect":         { "$ref": "#/$defs/effect" },
        "transformation": { "$ref": "#/$defs/TransformationInstance" }
      },
      "not": { "required": ["principal"] },
      "allOf": [
        {
          "description": "ADR-022: transformation is required iff effect is transform.",
          "if": {
            "properties": { "effect": { "enum": ["transform", "tessera:transform"] } },
            "required": ["effect"]
          },
          "then": { "required": ["transformation"] },
          "else": { "not": { "required": ["transformation"] } }
        }
      ]
    },

    "policyConstraint": {
      "title": "Tessera policy constraint",
      "description": "The structural properties of a single-rule policy constraint per technical-design-v0.2.md §4.2. Used by the backward-compat single-constraint document shape and the legacy @graph shape.",
      "type": "object",
      "required": ["@type", "appliesTo", "principal", "action", "effect"],
      "properties": {
        "@id":           { "type": "string", "minLength": 1 },
        "@type":         { "$ref": "#/$defs/policyType" },
        "version":       { "type": "string" },
        "description":   { "type": "string" },
        "appliesTo":     { "$ref": "#/$defs/resourceSelector" },
        "principal":     { "$ref": "#/$defs/principalSelector" },
        "action":        { "$ref": "#/$defs/action" },
        "effect":        { "$ref": "#/$defs/effect" },
        "condition":     { "$ref": "#/$defs/condition" },
        "transformation": { "$ref": "#/$defs/TransformationInstance" },
        "obligations":   { "type": "array", "items": { "$ref": "#/$defs/obligation" } },
        "capabilityRequirements": { "type": "array", "items": { "type": "string" } },
        "defaultStrategy": { "$ref": "#/$defs/defaultStrategy" },
        "baselineGroup": { "type": "string", "minLength": 1 },
        "provenance":    { "$ref": "#/$defs/provenance" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "defaultStrategy": { "const": "explicit-baseline-group" } },
            "required": ["defaultStrategy"]
          },
          "then": { "required": ["baselineGroup"] }
        },
        {
          "if": { "required": ["baselineGroup"] },
          "then": {
            "properties": { "defaultStrategy": { "const": "explicit-baseline-group" } },
            "required": ["defaultStrategy"]
          }
        },
        {
          "description": "ADR-022: transformation is required iff effect is transform (regardless of @type).",
          "if": {
            "properties": { "effect": { "enum": ["transform", "tessera:transform"] } },
            "required": ["effect"]
          },
          "then": { "required": ["transformation"] },
          "else": { "not": { "required": ["transformation"] } }
        }
      ]
    },

    "policyType": {
      "description": "The known policy constraint subclasses from the v0 ontology.",
      "enum": [
        "AccessConstraint",
        "RowVisibilityConstraint",
        "ColumnVisibilityConstraint",
        "DistributionConstraint",
        "tessera:AccessConstraint",
        "tessera:RowVisibilityConstraint",
        "tessera:ColumnVisibilityConstraint",
        "tessera:DistributionConstraint"
      ]
    },

    "action": {
      "description": "Action vocabulary per ontology v0. ADR-007 tracks the extensibility question; for v0 the set is closed. Execute added 2026-05-19 via table-grants exercise (scoped to semantic policy intent; platform-mechanism uses of EXECUTE remain adapter scaffolding).",
      "enum": [
        "Read", "Write", "Delete", "Share", "Sample", "Aggregate", "Execute",
        "tessera:Read", "tessera:Write", "tessera:Delete",
        "tessera:Share", "tessera:Sample", "tessera:Aggregate", "tessera:Execute"
      ]
    },

    "effect": {
      "description": "Effects a policy may declare.",
      "enum": [
        "allow", "deny", "transform", "keep-matching-rows", "drop-matching-rows",
        "tessera:allow", "tessera:deny", "tessera:transform",
        "tessera:keepMatchingRows", "tessera:dropMatchingRows"
      ]
    },

    "defaultStrategy": {
      "description": "Default-handling strategy per ADR-013.",
      "enum": [
        "explicit-baseline-group", "negated-complement", "none",
        "tessera:explicitBaselineGroup", "tessera:negatedComplement", "tessera:none"
      ]
    },

    "selectorKind": {
      "enum": [
        "byIdentity", "byAttribute", "byClassification", "byDataset", "byComposition", "byScope",
        "tessera:byIdentity", "tessera:byAttribute", "tessera:byClassification",
        "tessera:byDataset", "tessera:byComposition", "tessera:byScope"
      ]
    },

    "matching": {
      "title": "Attribute matching expression",
      "description": "Predicate over resource attributes per ADR-020. Accepts either the canonical form (match + criteria over the byComposition algebra) or the implicit-AND sugar (attributes map keyed by axis short-name).",
      "type": "object",
      "oneOf": [
        {
          "title": "Canonical (match + criteria)",
          "required": ["match", "criteria"],
          "properties": {
            "match": { "$ref": "#/$defs/booleanMatch" },
            "criteria": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/matchingCriterion" }
            }
          }
        },
        {
          "title": "Implicit-AND sugar (attributes map)",
          "required": ["attributes"],
          "properties": {
            "attributes": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "description": "Axis value. String for flat-axis named individuals or sensitivity-class short names; the schema does not enforce axis-value-domain pairing (SHACL does, when shapes.ttl exists).",
                "type": ["string", "number", "boolean"]
              }
            }
          }
        }
      ]
    },

    "matchingCriterion": {
      "title": "A leaf or nested expression inside a canonical matching criteria list",
      "oneOf": [
        { "$ref": "#/$defs/attributeMatcher" },
        { "$ref": "#/$defs/matching" }
      ]
    },

    "attributeMatcher": {
      "title": "Attribute matcher (axis-value leaf)",
      "type": "object",
      "required": ["attribute"],
      "properties": {
        "attribute": {
          "type": "object",
          "required": ["axis", "value"],
          "properties": {
            "axis": {
              "type": "string",
              "minLength": 1,
              "description": "Axis short-name (e.g., sensitivity, dataSubject) or CURIE (e.g., bg:rowDiscriminator). Adopter-namespaced axes use the prefix:name form."
            },
            "value": {
              "type": ["string", "number", "boolean"],
              "description": "Axis value. For sensitivity (hierarchical), a Classification class short-name. For flat axes, a named-individual short-name. Adopter values follow the same pattern."
            }
          }
        }
      }
    },

    "resourceSelector": {
      "title": "Resource selector",
      "description": "Identifies the resource(s) the policy applies to. byScope per ADR-019 enables scoped (catalog/schema/table/column) attachment with optional attribute matching.",
      "type": "object",
      "required": ["selector"],
      "properties": {
        "selector": { "$ref": "#/$defs/selectorKind" },
        "resource": { "type": "string", "minLength": 1 },
        "classification": { "type": "string", "minLength": 1 },
        "dataset": { "$ref": "#/$defs/setFromTable" },
        "match": { "$ref": "#/$defs/booleanMatch" },
        "criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/resourceSelector" }
        },
        "scope":  { "type": "string", "minLength": 1 },
        "except": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "matching": { "$ref": "#/$defs/matching" }
      },
      "oneOf": [
        {
          "properties": { "selector": { "enum": ["byIdentity", "tessera:byIdentity"] } },
          "required": ["resource"]
        },
        {
          "properties": { "selector": { "enum": ["byClassification", "tessera:byClassification"] } },
          "required": ["classification"]
        },
        {
          "properties": { "selector": { "enum": ["byDataset", "tessera:byDataset"] } },
          "required": ["dataset"]
        },
        {
          "properties": { "selector": { "enum": ["byComposition", "tessera:byComposition"] } },
          "required": ["match", "criteria"]
        },
        {
          "properties": { "selector": { "enum": ["byScope", "tessera:byScope"] } },
          "required": ["scope"]
        },
        {
          "properties": { "selector": { "enum": ["byAttribute", "tessera:byAttribute"] } }
        }
      ]
    },

    "principalSelector": {
      "title": "Principal selector",
      "description": "Identifies the principal(s) the policy applies to. Same shape as resource selector except dataset shape is PrincipalSetFromTable and composition criteria are principal selectors.",
      "type": "object",
      "required": ["selector"],
      "properties": {
        "selector": { "$ref": "#/$defs/selectorKind" },
        "resource": { "type": "string", "minLength": 1 },
        "dataset": { "$ref": "#/$defs/setFromTable" },
        "match": { "$ref": "#/$defs/booleanMatch" },
        "criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/principalSelector" }
        }
      },
      "oneOf": [
        {
          "properties": { "selector": { "enum": ["byIdentity", "tessera:byIdentity"] } },
          "required": ["resource"]
        },
        {
          "properties": { "selector": { "enum": ["byDataset", "tessera:byDataset"] } },
          "required": ["dataset"]
        },
        {
          "properties": { "selector": { "enum": ["byComposition", "tessera:byComposition"] } },
          "required": ["match", "criteria"]
        },
        {
          "properties": { "selector": { "enum": ["byAttribute", "tessera:byAttribute"] } }
        }
      ]
    },

    "setFromTable": {
      "title": "PrincipalSetFromTable / ResourceSetFromTable",
      "type": "object",
      "required": ["table"],
      "properties": {
        "@type": {
          "enum": [
            "PrincipalSetFromTable", "ResourceSetFromTable",
            "tessera:PrincipalSetFromTable", "tessera:ResourceSetFromTable"
          ]
        },
        "table":             { "type": "string", "minLength": 1 },
        "principalColumn":   { "type": "string", "minLength": 1 },
        "resourceColumn":    { "type": "string", "minLength": 1 },
        "permissionColumn":  { "type": "string", "minLength": 1 },
        "permissionValue":   { "type": "string" }
      }
    },

    "booleanMatch": {
      "enum": ["and", "or", "not", "tessera:and", "tessera:or", "tessera:not"]
    },

    "condition": {
      "title": "Condition",
      "type": "object",
      "required": ["op"],
      "properties": {
        "op": { "$ref": "#/$defs/conditionOperator" },
        "operands": { "type": "array" },
        "values":   { "type": "array" }
      }
    },

    "conditionOperator": {
      "enum": [
        "and", "or", "not",
        "eq", "lt", "gt", "in",
        "purpose-in", "located-in", "time-window", "consent-granted",
        "exists-in-dataset",
        "tessera:and", "tessera:or", "tessera:not",
        "tessera:eq", "tessera:lt", "tessera:gt", "tessera:in",
        "tessera:purposeIn", "tessera:locatedIn", "tessera:timeWindow",
        "tessera:consentGranted", "tessera:existsInDataset"
      ]
    },

    "TransformationInstance": {
      "title": "Transformation instance",
      "description": "A specific application of a Transformation, per ADR-016. Required for ColumnVisibility rules. The `type` field identifies the transformation kind; additional fields carry per-kind parameters. Uniform structured form applies even for parameterless transformations (e.g., Hash with default algorithm).",
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["Mask", "Hash", "Tokenize", "Redact", "Bucketize"]
        },
        "replacement": {
          "description": "Required iff type is Redact. JSON-encodable value.",
          "type": ["string", "number", "boolean", "null"]
        },
        "maskChar": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1,
          "default": "X"
        },
        "preserveFirst": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "preserveLast": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "algorithm": {
          "type": "string",
          "enum": ["sha256", "sha512", "sha1"],
          "default": "sha256"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "Redact" } }
          },
          "then": {
            "required": ["replacement"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "Mask" } }
          },
          "then": {
            "not": { "required": ["replacement"] }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "Hash" } }
          },
          "then": {
            "not": { "required": ["replacement"] }
          }
        }
      ]
    },

    "obligation": {
      "title": "Obligation",
      "type": "object",
      "required": ["@type"],
      "properties": {
        "@type": {
          "enum": [
            "AuditLog", "Notify", "Watermark",
            "tessera:AuditLog", "tessera:Notify", "tessera:Watermark"
          ]
        },
        "target": { "type": "string" }
      }
    },

    "provenance": {
      "title": "Provenance",
      "type": "object",
      "properties": {
        "extractedFrom":      { "type": "string" },
        "extractedAt":        { "type": "string", "format": "date-time" },
        "confidence":         { "enum": ["high", "medium", "low", "tessera:confidenceHigh", "tessera:confidenceMedium", "tessera:confidenceLow"] },
        "notes":              { "type": "string" },
        "originalConstruct":  { "type": "string" }
      }
    }
  }
}
