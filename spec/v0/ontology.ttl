# Tessera Ontology v0
#
# This file defines the formal semantics of the Tessera vocabulary.
# It is immutable once published; future versions are published at
# parallel URLs (v1, v2, ...) and may extend or supersede this one
# but do not modify it in place.
#
# Companion artifacts:
#   - spec/v0/context.jsonld    JSON-LD context mapping short names to these IRIs
#   - spec/v0/shapes.ttl        SHACL shapes for semantic validation (planned)
#   - docs/technical-design-v0.2.md  Architectural context
#   - DECISIONS.md              ADRs governing the ontology, especially 004 and 005
#
# Standards alignment (per ADR-005):
#   - W3C DPV: purposes, personal data categories
#   - W3C ODRL: permission/prohibition/duty patterns
#   - Cedar:   principal/resource/action shape
#   - XACML:   obligation algebra
# Tessera does not formally import these vocabularies; it documents alignment
# at the level of individual terms and reuses external IRIs where exact
# correspondence exists.

@prefix tessera: <https://bgiesbrecht.github.io/tessera/spec/v0/vocab#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dpv:     <https://w3id.org/dpv#> .
@prefix odrl:    <http://www.w3.org/ns/odrl/2/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .

#
# Ontology header
#

<https://bgiesbrecht.github.io/tessera/spec/v0/vocab> a owl:Ontology ;
    dcterms:title "Tessera Vocabulary"@en ;
    dcterms:description
        """A vocabulary for expressing data governance policies portably across heterogeneous data platforms. Tessera captures intent (classification, purpose, principal, conditions, obligations) in a form independent of any specific platform's enforcement mechanisms."""@en ;
    owl:versionInfo "0.0.1" ;
    rdfs:seeAlso <https://github.com/bgiesbrecht/tessera> .


#
# ============================================================================
# Top-level abstract classes
# ============================================================================
#

tessera:Entity a owl:Class ;
    rdfs:label "Entity"@en ;
    rdfs:comment
        """Abstract superclass of all Tessera vocabulary entities. Not instantiated directly; exists to give downstream tooling a single type hierarchy root."""@en .


#
# ============================================================================
# Principals
# ============================================================================
# Aligned with Cedar's principal model. A Principal is anything that can
# take an Action on a Resource.
#

tessera:Principal a owl:Class ;
    rdfs:subClassOf tessera:Entity ;
    rdfs:label "Principal"@en ;
    rdfs:comment
        """An identifiable actor who may take an Action on a Resource. Subclasses specialize by kind of actor."""@en .

tessera:User a owl:Class ;
    rdfs:subClassOf tessera:Principal ;
    rdfs:label "User"@en ;
    rdfs:comment "An individual human principal, identified by an identity provider URI."@en .

tessera:Group a owl:Class ;
    rdfs:subClassOf tessera:Principal ;
    rdfs:label "Group"@en ;
    rdfs:comment
        """A collection of principals treated as a single principal for policy purposes. Membership is resolved by the identity provider."""@en .

tessera:ServiceAccount a owl:Class ;
    rdfs:subClassOf tessera:Principal ;
    rdfs:label "Service account"@en ;
    rdfs:comment "A non-human principal representing an automated system or service."@en .

tessera:Role a owl:Class ;
    rdfs:subClassOf tessera:Principal ;
    rdfs:label "Role"@en ;
    rdfs:comment
        """A named capability claim that principals may hold. Distinct from Group: a role is a logical capability; a group is a collection of principals. Many systems conflate the two; Tessera preserves the distinction at the vocabulary level even when adapters collapse it."""@en .


#
# ============================================================================
# Resources
# ============================================================================
# What policies protect. The hierarchy mirrors the natural granularity of
# data platforms: data products contain schemas, schemas contain tables,
# tables contain columns and (logical) row sets.
#

tessera:Resource a owl:Class ;
    rdfs:subClassOf tessera:Entity ;
    rdfs:label "Resource"@en ;
    rdfs:comment "A protected thing on which Principals may take Actions."@en .

tessera:DataProduct a owl:Class ;
    rdfs:subClassOf tessera:Resource ;
    rdfs:label "Data product"@en ;
    rdfs:comment
        """A logical grouping of data assets treated as a unit for governance purposes. Aligned with the Data Mesh notion of a data product."""@en .

tessera:Schema a owl:Class ;
    rdfs:subClassOf tessera:Resource ;
    rdfs:label "Schema"@en ;
    rdfs:comment "A namespace containing tables, views, and related catalog objects."@en .

tessera:Table a owl:Class ;
    rdfs:subClassOf tessera:Resource ;
    rdfs:label "Table"@en .

tessera:View a owl:Class ;
    rdfs:subClassOf tessera:Resource ;
    rdfs:label "View"@en .

tessera:Column a owl:Class ;
    rdfs:subClassOf tessera:Resource ;
    rdfs:label "Column"@en ;
    rdfs:comment "A column of a Table or View."@en .

tessera:RowSet a owl:Class ;
    rdfs:subClassOf tessera:Resource ;
    rdfs:label "Row set"@en ;
    rdfs:comment
        """A logical subset of rows in a Table or View, defined by a predicate. RowSet is the resource targeted by RowVisibilityConstraint. It is logical: a RowSet has no independent existence beyond the predicate that defines it."""@en .


#
# ============================================================================
# Actions
# ============================================================================
# What principals may attempt on resources. The set is intentionally small
# in v0; extensibility is governed by ADR-007.
#

tessera:Action a owl:Class ;
    rdfs:subClassOf tessera:Entity ;
    rdfs:label "Action"@en ;
    rdfs:comment "An operation a Principal may take on a Resource."@en .

tessera:Read     a tessera:Action ; rdfs:label "Read"@en .
tessera:Write    a tessera:Action ; rdfs:label "Write"@en .
tessera:Delete   a tessera:Action ; rdfs:label "Delete"@en .
tessera:Share    a tessera:Action ; rdfs:label "Share"@en ;
    rdfs:comment "Distribute a Resource beyond its origin (cross-account, cross-region, etc.)."@en .
tessera:Sample   a tessera:Action ; rdfs:label "Sample"@en ;
    rdfs:comment "Read a representative subset of rows; distinct from Read for policies that permit sampling but not full retrieval."@en .
tessera:Aggregate a tessera:Action ; rdfs:label "Aggregate"@en ;
    rdfs:comment "Read summary statistics over rows without reading individual rows; distinct from Read for differential-privacy-aware policies."@en .


#
# ============================================================================
# Classifications
# ============================================================================
# Labels applied to Resources indicating sensitivity, regulatory status, or
# business category. Hierarchical: a policy that applies to PersonalData
# applies to all subclasses (PII, PHI, etc.) by inheritance.
#
# Classifications align with W3C DPV for the privacy subtree. Organizations
# extend the hierarchy by declaring their own classifications as subclasses
# under their own namespace.
#

tessera:Classification a owl:Class ;
    rdfs:subClassOf tessera:Entity ;
    rdfs:label "Classification"@en ;
    rdfs:comment
        """A label applied to a Resource indicating its sensitivity, regulatory status, or business category. Classifications form a hierarchy under rdfs:subClassOf; reasoners propagate policies across the hierarchy automatically."""@en .

# --- Privacy classifications (aligned with DPV) ---

tessera:PersonalData a owl:Class ;
    rdfs:subClassOf tessera:Classification ;
    rdfs:label "Personal data"@en ;
    rdfs:comment "Data relating to an identified or identifiable natural person."@en ;
    skos:exactMatch dpv:PersonalData .

tessera:PII a owl:Class ;
    rdfs:subClassOf tessera:PersonalData ;
    rdfs:label "Personally identifiable information"@en ;
    rdfs:comment
        """Personal data that directly or indirectly identifies a specific individual. Tessera treats PII as a subclass of PersonalData; in some regulatory frameworks the terms are synonymous."""@en .

tessera:PHI a owl:Class ;
    rdfs:subClassOf tessera:PII ;
    rdfs:label "Protected health information"@en ;
    rdfs:comment "Personal data related to health, treatment, or healthcare payment, subject to HIPAA-style protections."@en .

tessera:SensitivePersonalData a owl:Class ;
    rdfs:subClassOf tessera:PersonalData ;
    rdfs:label "Sensitive personal data"@en ;
    rdfs:comment "Personal data of categories afforded special protection (e.g., GDPR Article 9 categories)."@en ;
    skos:closeMatch dpv:SensitivePersonalData .

# --- Business classifications ---

tessera:Financial a owl:Class ;
    rdfs:subClassOf tessera:Classification ;
    rdfs:label "Financial data"@en ;
    rdfs:comment "Data relating to financial transactions, balances, or accounts. May overlap with PersonalData; not a subclass."@en .

tessera:Public a owl:Class ;
    rdfs:subClassOf tessera:Classification ;
    rdfs:label "Public"@en ;
    rdfs:comment "Data explicitly designated for unrestricted disclosure."@en .

tessera:Confidential a owl:Class ;
    rdfs:subClassOf tessera:Classification ;
    rdfs:label "Confidential"@en ;
    rdfs:comment "Data whose disclosure is restricted to designated principals."@en .

tessera:Restricted a owl:Class ;
    rdfs:subClassOf tessera:Confidential ;
    rdfs:label "Restricted"@en ;
    rdfs:comment "Data whose disclosure is restricted under stronger controls than ordinary Confidential."@en .


#
# ============================================================================
# AttributeAxis: orthogonal semantic dimensions for resource attributes
# ============================================================================
# Introduced in ADR-018. Each axis names an independent semantic dimension
# (sensitivity, data subject, regulatory regime, business domain). Resources
# carry zero or more attribute assignments — one value per axis they
# participate in. Axes are orthogonal: a column may simultaneously be
# `sensitivity: PIIEmail`, `dataSubject: EUResident`, `regulatoryRegime: GDPR`.
#
# Each axis declares its structural type:
#   - hierarchical: values form a subsumption hierarchy (rdfs:subClassOf)
#   - flat:         values are independent enumeration members (no subsumption)
#
# Adopters extend with their own axes under their own namespace.
#

tessera:AttributeAxis a owl:Class ;
    rdfs:subClassOf tessera:Entity ;
    rdfs:label "Attribute axis"@en ;
    rdfs:comment
        """Names an independent semantic dimension for resource attributes. Resources carry zero or more attribute values, one per axis. See ADR-018."""@en .

# Axis structural type markers
tessera:hierarchical a owl:NamedIndividual ; rdfs:label "hierarchical"@en ;
    rdfs:comment "Axis values form a subsumption hierarchy via rdfs:subClassOf."@en .
tessera:flat a owl:NamedIndividual ; rdfs:label "flat"@en ;
    rdfs:comment "Axis values are independent enumeration members; no subsumption."@en .

tessera:axisType a owl:ObjectProperty ;
    rdfs:label "axis type"@en ;
    rdfs:comment
        """Declares whether an axis is hierarchical (values participate in subClassOf subsumption) or flat (values are independent enumeration members)."""@en ;
    rdfs:domain tessera:AttributeAxis .

# The four well-known v0 axes
tessera:sensitivityAxis a tessera:AttributeAxis ;
    rdfs:label "sensitivity axis"@en ;
    tessera:axisType tessera:hierarchical ;
    rdfs:comment
        """Sensitivity classification. Values form a hierarchy (PIIEmail ⊂ PII ⊂ PersonalData; Public, Confidential as siblings). Existing tessera:Classification subclasses are the values on this axis. Aligned with DPV PersonalDataCategory."""@en .

tessera:dataSubjectAxis a tessera:AttributeAxis ;
    rdfs:label "data subject axis"@en ;
    tessera:axisType tessera:flat ;
    rdfs:comment
        """Identifies who the data is about. Values are independent enumeration members (EUResident, USResident, Employee, Customer, Minor). Aligned with DPV DataSubject."""@en .

tessera:regulatoryRegimeAxis a tessera:AttributeAxis ;
    rdfs:label "regulatory regime axis"@en ;
    tessera:axisType tessera:flat ;
    rdfs:comment
        """Regulatory framework under which the data is protected. Values are independent (GDPR, HIPAA, PCI-DSS, SOX, CCPA)."""@en .

tessera:businessDomainAxis a tessera:AttributeAxis ;
    rdfs:label "business domain axis"@en ;
    tessera:axisType tessera:flat ;
    rdfs:comment
        """Organizational classification (CRM, Finance, HR, Engineering, Marketing). v0 declares this axis flat; adopters who model org hierarchies may declare a hierarchical extension under their own namespace."""@en .

# Per-axis properties on Resource. Each axis is its own property; values are
# either classes (hierarchical axis) or named individuals (flat axis).
tessera:sensitivity a owl:ObjectProperty ;
    rdfs:label "sensitivity"@en ;
    rdfs:comment
        """Relates a Resource to its sensitivity value. Hierarchical axis: values are tessera:Classification subclasses. Subsumption applies."""@en ;
    rdfs:domain tessera:Resource ;
    rdfs:range tessera:Classification .

tessera:dataSubject a owl:ObjectProperty ;
    rdfs:label "data subject"@en ;
    rdfs:comment "Relates a Resource to its data-subject classification (flat axis)."@en ;
    rdfs:domain tessera:Resource .

tessera:regulatoryRegime a owl:ObjectProperty ;
    rdfs:label "regulatory regime"@en ;
    rdfs:comment "Relates a Resource to its applicable regulatory regime(s) (flat axis)."@en ;
    rdfs:domain tessera:Resource .

tessera:businessDomain a owl:ObjectProperty ;
    rdfs:label "business domain"@en ;
    rdfs:comment "Relates a Resource to its business domain (flat axis)."@en ;
    rdfs:domain tessera:Resource .

# Well-known values for the flat axes (starter set). Adopters extend.
tessera:EUResident a owl:NamedIndividual ; rdfs:label "EU resident"@en .
tessera:USResident a owl:NamedIndividual ; rdfs:label "US resident"@en .
tessera:Employee   a owl:NamedIndividual ; rdfs:label "Employee"@en .
tessera:Customer   a owl:NamedIndividual ; rdfs:label "Customer"@en .
tessera:Minor      a owl:NamedIndividual ; rdfs:label "Minor"@en .

tessera:GDPR    a owl:NamedIndividual ; rdfs:label "GDPR"@en .
tessera:HIPAA   a owl:NamedIndividual ; rdfs:label "HIPAA"@en .
tessera:PCI_DSS a owl:NamedIndividual ; rdfs:label "PCI-DSS"@en .
tessera:SOX     a owl:NamedIndividual ; rdfs:label "SOX"@en .
tessera:CCPA    a owl:NamedIndividual ; rdfs:label "CCPA"@en .

tessera:CRM         a owl:NamedIndividual ; rdfs:label "CRM"@en .
tessera:Finance     a owl:NamedIndividual ; rdfs:label "Finance"@en .
tessera:HR          a owl:NamedIndividual ; rdfs:label "HR"@en .
tessera:Engineering a owl:NamedIndividual ; rdfs:label "Engineering"@en .
tessera:MarketingDomain a owl:NamedIndividual ; rdfs:label "Marketing domain"@en ;
    rdfs:comment "Disambiguated from tessera:Marketing (a Purpose) by the 'Domain' suffix."@en .


#
# ============================================================================
# Purposes
# ============================================================================
# A Purpose is a declared reason for access, claimed by a Principal at
# session or query time. Purposes align with DPV's purpose taxonomy.
#

tessera:Purpose a owl:Class ;
    rdfs:subClassOf tessera:Entity ;
    rdfs:label "Purpose"@en ;
    rdfs:comment "A declared reason for accessing data, claimed by a Principal."@en ;
    skos:exactMatch dpv:Purpose .

tessera:Analytics          a tessera:Purpose ; rdfs:label "Analytics"@en .
tessera:Operations         a tessera:Purpose ; rdfs:label "Operations"@en .
tessera:FraudInvestigation a tessera:Purpose ; rdfs:label "Fraud investigation"@en .
tessera:Audit              a tessera:Purpose ; rdfs:label "Audit"@en .
tessera:Compliance         a tessera:Purpose ; rdfs:label "Compliance"@en .
tessera:Marketing          a tessera:Purpose ; rdfs:label "Marketing"@en .


#
# ============================================================================
# Jurisdictions
# ============================================================================
#

tessera:Jurisdiction a owl:Class ;
    rdfs:subClassOf tessera:Entity ;
    rdfs:label "Jurisdiction"@en ;
    rdfs:comment "A geographic or legal boundary relevant to policy applicability."@en .


#
# ============================================================================
# Policy constraint classes
# ============================================================================
# Policies are named by what they constrain (the abstract function),
# not by how they are enforced (the platform-specific mechanism).
# See technical-design-v0.2 §3.2 for the design rationale.
#

tessera:PolicyConstraint a owl:Class ;
    rdfs:subClassOf tessera:Entity ;
    rdfs:label "Policy constraint"@en ;
    rdfs:comment
        """Abstract superclass of all policies. A policy constrains how a Principal may interact with a Resource, optionally subject to Conditions and producing Obligations."""@en .

tessera:AccessConstraint a owl:Class ;
    rdfs:subClassOf tessera:PolicyConstraint ;
    rdfs:label "Access constraint"@en ;
    rdfs:comment
        """Constrains whether a Principal may take an Action on a Resource. Typical enforcement mechanisms: grants, denials, role assignments."""@en .

tessera:RowVisibilityConstraint a owl:Class ;
    rdfs:subClassOf tessera:PolicyConstraint ;
    rdfs:label "Row visibility constraint"@en ;
    rdfs:comment
        """Constrains which rows of a Resource a Principal may see. Typical enforcement mechanisms: row-level security, row access policies, view filters, ACL joins."""@en .

tessera:ColumnVisibilityConstraint a owl:Class ;
    rdfs:subClassOf tessera:PolicyConstraint ;
    rdfs:label "Column visibility constraint"@en ;
    rdfs:comment
        """Constrains whether a Principal sees a Column's true value, a transformed value, or no value. Typical enforcement mechanisms: column masking, dynamic data masking, view projections."""@en .

tessera:DistributionConstraint a owl:Class ;
    rdfs:subClassOf tessera:PolicyConstraint ;
    rdfs:label "Distribution constraint"@en ;
    rdfs:comment
        """Constrains whether and how a Resource may be shared beyond its origin. Typical enforcement mechanisms: secure shares, listings, Delta Sharing, replication controls."""@en .


#
# ============================================================================
# Policy container
# ============================================================================
# A Policy is a container that holds an ordered set of rules plus
# policy-level metadata. Introduced in ADR-014 to give multi-branch
# policies first-class structural representation. A single-rule policy
# may also be expressed as a Policy with a one-element `rules` list, but
# bare PolicyConstraint top-level forms remain valid for backward
# compatibility.
#
# Rule combining is ordered first-match (ADR-015): the first rule whose
# principal and condition both match wins; subsequent rules are not
# evaluated. The `defaultStrategy` field on Policy determines what
# happens when no rule matches.
#

tessera:Policy a owl:Class ;
    rdfs:subClassOf tessera:Entity ;
    rdfs:label "Policy"@en ;
    rdfs:comment
        """A container holding an ordered set of rules plus policy-level metadata (appliesTo, defaultStrategy, baselineGroup, defaultBranch, policyKind). A Policy is not a subclass of PolicyConstraint; it contains constraints rather than refining the constraint concept. See ADR-014 for the introduction of this class."""@en .


#
# ============================================================================
# Default-handling strategy
# ============================================================================
# When a policy has multiple branches, the strategy for handling principals
# who match no affirmative branch is part of the policy's intent, not just
# its observable behavior. Two policies producing identical SQL may differ
# in whether the default visibility is grounded in an explicit baseline
# group or in the absence of restrictive memberships. See ADR-013.
#

tessera:DefaultStrategy a owl:Class ;
    rdfs:subClassOf tessera:Entity ;
    rdfs:label "Default strategy"@en ;
    rdfs:comment
        """Names the mechanism by which a policy handles principals who do not match its affirmative-grant rules. Captures intent: same observable behavior can be produced by different strategies, and the choice between them is part of the policy's meaning."""@en .

tessera:explicitBaselineGroup a tessera:DefaultStrategy ;
    rdfs:label "explicit baseline group"@en ;
    rdfs:comment
        """The policy asserts a specific group is the universal baseline. A companion field, baselineGroup, names the group. The framework treats the rule keyed off this group as the default branch. The default is grounded in explicit group membership."""@en .

tessera:negatedComplement a tessera:DefaultStrategy ;
    rdfs:label "negated complement"@en ;
    rdfs:comment
        """The policy asserts no baseline group. The default branch applies to principals who do not match any affirmative-grant rule. The framework treats the negation as inherent to the policy structure. The default is grounded in the absence of restrictive memberships."""@en .

tessera:none a tessera:DefaultStrategy ;
    rdfs:label "none"@en ;
    rdfs:comment
        """The policy has no default branch. Principals matching no rule see nothing. This is the framework's fail-closed disposition stated explicitly. Equivalent to omitting the defaultStrategy field, but preferred when the policy author wants to assert the choice."""@en .


#
# ============================================================================
# Selectors
# ============================================================================
# A Selector identifies the set of principals or resources a policy applies
# to. The byDataset selector is the v0 mechanism that supports data-driven
# principal/resource sets, including custom ACL-table patterns (ADR-003).
#

tessera:Selector a owl:Class ;
    rdfs:subClassOf tessera:Entity ;
    rdfs:label "Selector"@en ;
    rdfs:comment "Identifies a set of principals or resources by some criterion."@en .

tessera:PrincipalSelector a owl:Class ;
    rdfs:subClassOf tessera:Selector ;
    rdfs:label "Principal selector"@en .

tessera:ResourceSelector a owl:Class ;
    rdfs:subClassOf tessera:Selector ;
    rdfs:label "Resource selector"@en .

# Selector kinds, used as values of the selectorKind property
tessera:byIdentity       a owl:NamedIndividual ; rdfs:label "by identity"@en .
tessera:byAttribute      a owl:NamedIndividual ; rdfs:label "by attribute"@en .
tessera:byScope          a owl:NamedIndividual ; rdfs:label "by scope"@en ;
    rdfs:comment
        """Selector kind for scoped (catalog/schema/table/column) policy attachment per ADR-019. A byScope selector carries a scope (a resource IRI), an optional except list, and an optional matching block (attribute predicates that narrow which resources within the scope the policy applies to)."""@en .
tessera:byClassification a owl:NamedIndividual ; rdfs:label "by classification"@en .
tessera:byDataset        a owl:NamedIndividual ; rdfs:label "by dataset"@en .
tessera:byComposition    a owl:NamedIndividual ; rdfs:label "by composition"@en .

# Data-driven principal/resource sets, defined as objects rather than mere
# property values because they carry multiple structural fields.

tessera:PrincipalSetFromTable a owl:Class ;
    rdfs:subClassOf tessera:PrincipalSelector ;
    rdfs:label "Principal set from table"@en ;
    rdfs:comment
        """A principal set computed from rows in a data table. The table is joined at policy-evaluation time (or materialized at emit time, depending on adapter capability) against the principal taking the action. Supports the custom ACL-table pattern."""@en .

tessera:ResourceSetFromTable a owl:Class ;
    rdfs:subClassOf tessera:ResourceSelector ;
    rdfs:label "Resource set from table"@en ;
    rdfs:comment "A resource set computed from rows in a data table; the resource analogue of PrincipalSetFromTable."@en .


#
# ============================================================================
# Conditions
# ============================================================================
# A Condition is a predicate that must hold for a policy to apply. The
# condition algebra is closed by design (ADR-007 tracks the extensibility
# question). All conditions are expressible from a fixed set of operators.
#

tessera:Condition a owl:Class ;
    rdfs:subClassOf tessera:Entity ;
    rdfs:label "Condition"@en ;
    rdfs:comment "A predicate that must hold for a policy to apply."@en .

# Boolean combinators
tessera:and a owl:NamedIndividual ; rdfs:label "and"@en .
tessera:or  a owl:NamedIndividual ; rdfs:label "or"@en .
tessera:not a owl:NamedIndividual ; rdfs:label "not"@en .

# Comparisons
tessera:eq a owl:NamedIndividual ; rdfs:label "equals"@en .
tessera:lt a owl:NamedIndividual ; rdfs:label "less than"@en .
tessera:gt a owl:NamedIndividual ; rdfs:label "greater than"@en .
tessera:in a owl:NamedIndividual ; rdfs:label "is in"@en .

# Context predicates
tessera:purposeIn       a owl:NamedIndividual ; rdfs:label "purpose in"@en .
tessera:locatedIn       a owl:NamedIndividual ; rdfs:label "located in"@en .
tessera:timeWindow      a owl:NamedIndividual ; rdfs:label "time window"@en .
tessera:consentGranted  a owl:NamedIndividual ; rdfs:label "consent granted"@en .

# Dataset predicates
tessera:existsInDataset a owl:NamedIndividual ;
    rdfs:label "exists in dataset"@en ;
    rdfs:comment "True if a matching row exists in the referenced dataset (used with byDataset selectors)."@en .


#
# ============================================================================
# Obligations
# ============================================================================
# An Obligation is an action that must occur as a consequence of policy
# application. Aligned with XACML obligations and ODRL duties.
#

tessera:Obligation a owl:Class ;
    rdfs:subClassOf tessera:Entity ;
    rdfs:label "Obligation"@en ;
    rdfs:comment
        """An action that must occur as a consequence of a policy applying. Distinct from Conditions: conditions gate whether a policy applies; obligations are consequences when it does."""@en ;
    skos:closeMatch odrl:Duty .

tessera:AuditLog a owl:Class ;
    rdfs:subClassOf tessera:Obligation ;
    rdfs:label "Audit log obligation"@en ;
    rdfs:comment "Record the access event to a named audit destination."@en .

tessera:Notify a owl:Class ;
    rdfs:subClassOf tessera:Obligation ;
    rdfs:label "Notify obligation"@en ;
    rdfs:comment "Send a notification to a named target when the policy applies."@en .

tessera:Watermark a owl:Class ;
    rdfs:subClassOf tessera:Obligation ;
    rdfs:label "Watermark obligation"@en ;
    rdfs:comment "Embed a watermark identifying the accessing principal in the returned data."@en .


#
# ============================================================================
# Transformations
# ============================================================================
# A Transformation is a function applied to data on read, parameterized.
# The transformation vocabulary is closed in v0 to preserve portability
# (ADR-007 tracks extensibility). Parameter shapes are formalized via
# TransformationInstance per ADR-016.
#

tessera:Transformation a owl:Class ;
    rdfs:subClassOf tessera:Entity ;
    rdfs:label "Transformation"@en ;
    rdfs:comment
        """A function applied to data on read. Subclasses name the function (Mask, Hash, Redact, etc.); the parameters of a specific application of that function live on a TransformationInstance."""@en .

tessera:Mask       a owl:Class ; rdfs:subClassOf tessera:Transformation ; rdfs:label "Mask"@en .
tessera:Hash       a owl:Class ; rdfs:subClassOf tessera:Transformation ; rdfs:label "Hash"@en .
tessera:Tokenize   a owl:Class ; rdfs:subClassOf tessera:Transformation ; rdfs:label "Tokenize"@en .
tessera:Redact     a owl:Class ; rdfs:subClassOf tessera:Transformation ; rdfs:label "Redact"@en .
tessera:Bucketize  a owl:Class ; rdfs:subClassOf tessera:Transformation ; rdfs:label "Bucketize"@en .

# --- TransformationInstance: a specific application of a Transformation ----
# Per ADR-016, every reference to a transformation in a policy is a
# TransformationInstance, even for parameterless cases (uniform structured
# form). The `type` field identifies which Transformation subclass applies;
# the additional properties carry parameters specific to that transformation.

tessera:TransformationInstance a owl:Class ;
    rdfs:subClassOf tessera:Entity ;
    rdfs:label "Transformation instance"@en ;
    rdfs:comment
        """A specific application of a Transformation, carrying any parameters required. The `type` property identifies the Transformation subclass; additional properties carry per-transformation parameters. See ADR-016 for the parameter shapes formalized in v0."""@en .

tessera:replacement a owl:DatatypeProperty ;
    rdfs:label "replacement"@en ;
    rdfs:comment
        """The literal value to substitute for the column's content when a Redact transformation is applied. Accepts JSON-encodable values: strings, numbers, booleans, or null. The adapter is responsible for type-compatibility with the column at emission time."""@en ;
    rdfs:domain tessera:TransformationInstance .

tessera:maskChar a owl:DatatypeProperty ;
    rdfs:label "mask character"@en ;
    rdfs:comment
        """The character used for masked positions in a Mask transformation. Single character; default 'X' if omitted."""@en ;
    rdfs:domain tessera:TransformationInstance ;
    rdfs:range xsd:string .

tessera:preserveFirst a owl:DatatypeProperty ;
    rdfs:label "preserve first N characters"@en ;
    rdfs:comment
        """Non-negative integer. The first N Unicode code points of the value pass through unchanged in a Mask transformation. Default 0."""@en ;
    rdfs:domain tessera:TransformationInstance ;
    rdfs:range xsd:nonNegativeInteger .

tessera:preserveLast a owl:DatatypeProperty ;
    rdfs:label "preserve last N characters"@en ;
    rdfs:comment
        """Non-negative integer. The last N Unicode code points of the value pass through unchanged in a Mask transformation. Default 0. If the sum of preserveFirst and preserveLast meets or exceeds the value's character length, the value is returned unchanged."""@en ;
    rdfs:domain tessera:TransformationInstance ;
    rdfs:range xsd:nonNegativeInteger .

tessera:algorithm a owl:DatatypeProperty ;
    rdfs:label "hash algorithm"@en ;
    rdfs:comment
        """The hash algorithm for a Hash transformation. One of 'sha256', 'sha512', 'sha1'. Default 'sha256'. Salted hashing is deferred to v1 pending secret-reference vocabulary."""@en ;
    rdfs:domain tessera:TransformationInstance ;
    rdfs:range xsd:string .


#
# ============================================================================
# Effects
# ============================================================================
# An Effect names what a policy does when it applies. Effects are individuals,
# not classes, because they are atomic markers consumed by adapters.
#

tessera:Effect a owl:Class ;
    rdfs:subClassOf tessera:Entity ;
    rdfs:label "Effect"@en .

tessera:allow             a tessera:Effect ; rdfs:label "allow"@en .
tessera:deny              a tessera:Effect ; rdfs:label "deny"@en .
tessera:transform         a tessera:Effect ; rdfs:label "transform"@en .
tessera:keepMatchingRows  a tessera:Effect ; rdfs:label "keep matching rows"@en .
tessera:dropMatchingRows  a tessera:Effect ; rdfs:label "drop matching rows"@en .


#
# ============================================================================
# Extraction confidence
# ============================================================================
# Every extracted policy carries a confidence level (technical-design v0.2 §4.3).
#

tessera:ExtractionConfidence a owl:Class ;
    rdfs:subClassOf tessera:Entity ;
    rdfs:label "Extraction confidence"@en .

tessera:confidenceHigh   a tessera:ExtractionConfidence ; rdfs:label "high"@en .
tessera:confidenceMedium a tessera:ExtractionConfidence ; rdfs:label "medium"@en .
tessera:confidenceLow    a tessera:ExtractionConfidence ; rdfs:label "low"@en .


#
# ============================================================================
# Properties
# ============================================================================
# Properties relate entities. Domain and range are specified where they
# constrain usage meaningfully; over-specification is avoided to keep the
# ontology flexible during v0.
#

# --- Policy structure ---

tessera:appliesTo a owl:ObjectProperty ;
    rdfs:label "applies to"@en ;
    rdfs:comment
        """Relates a policy (Policy container, or a standalone PolicyConstraint) to the resource selector identifying the resources it constrains. On a Policy, appliesTo is policy-wide and shared across all rules. See ADR-014 for the property's extension to Policy."""@en ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( tessera:Policy tessera:PolicyConstraint )
    ] ;
    rdfs:range tessera:ResourceSelector .

tessera:principal a owl:ObjectProperty ;
    rdfs:label "principal"@en ;
    rdfs:comment "Relates a policy constraint to the principal selector identifying the principals it constrains."@en ;
    rdfs:domain tessera:PolicyConstraint ;
    rdfs:range tessera:PrincipalSelector .

tessera:action a owl:ObjectProperty ;
    rdfs:label "action"@en ;
    rdfs:comment "Relates a policy constraint to the action it concerns."@en ;
    rdfs:domain tessera:PolicyConstraint ;
    rdfs:range tessera:Action .

tessera:effect a owl:ObjectProperty ;
    rdfs:label "effect"@en ;
    rdfs:comment "Relates a policy constraint to the effect it produces when it applies."@en ;
    rdfs:domain tessera:PolicyConstraint ;
    rdfs:range tessera:Effect .

tessera:condition a owl:ObjectProperty ;
    rdfs:label "condition"@en ;
    rdfs:comment "Relates a policy constraint to the condition that gates its application."@en ;
    rdfs:domain tessera:PolicyConstraint ;
    rdfs:range tessera:Condition .

tessera:transformation a owl:ObjectProperty ;
    rdfs:label "transformation"@en ;
    rdfs:comment
        """Relates a column visibility constraint to the transformation instance applied to matching data. Per ADR-016, every reference is a structured TransformationInstance carrying the transformation type and any applicable parameters."""@en ;
    rdfs:domain tessera:ColumnVisibilityConstraint ;
    rdfs:range tessera:TransformationInstance .

tessera:hasObligation a owl:ObjectProperty ;
    rdfs:label "has obligation"@en ;
    rdfs:comment "Relates a policy constraint to an obligation that must be honored when the policy applies."@en ;
    rdfs:domain tessera:PolicyConstraint ;
    rdfs:range tessera:Obligation .

tessera:requiresCapability a owl:DatatypeProperty ;
    rdfs:label "requires capability"@en ;
    rdfs:comment "Names a capability the policy depends on; consulted at emission time against the target adapter's capability profile."@en ;
    rdfs:domain tessera:PolicyConstraint ;
    rdfs:range xsd:string .

tessera:defaultStrategy a owl:ObjectProperty ;
    rdfs:label "default strategy"@en ;
    rdfs:comment
        """Relates a policy (Policy container, or a standalone PolicyConstraint) to the strategy by which it handles principals who match no affirmative rule. Optional; when omitted, the framework treats the policy as fail-closed (equivalent to tessera:none). See ADR-013 for the property's introduction and ADR-014 for its extension to Policy."""@en ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( tessera:Policy tessera:PolicyConstraint )
    ] ;
    rdfs:range tessera:DefaultStrategy .

tessera:baselineGroup a owl:DatatypeProperty ;
    rdfs:label "baseline group"@en ;
    rdfs:comment
        """Names the group treated as the universal baseline when defaultStrategy is tessera:explicitBaselineGroup. Required if and only if that strategy is in use. Value is the platform-native group identifier (e.g., 'account users' on Databricks). See ADR-013 for the property's introduction and ADR-014 for its extension to Policy."""@en ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( tessera:Policy tessera:PolicyConstraint )
    ] ;
    rdfs:range xsd:string .

tessera:policyKind a owl:ObjectProperty ;
    rdfs:label "policy kind"@en ;
    rdfs:comment
        """Discriminator selecting the policy domain (e.g., tessera:RowVisibilityConstraint) for a Policy. Determines the legal shape of rules within the Policy. See ADR-014."""@en ;
    rdfs:domain tessera:Policy ;
    rdfs:range rdfs:Class .

tessera:rules a owl:ObjectProperty ;
    rdfs:label "rules"@en ;
    rdfs:comment
        """Ordered list of rules in a Policy. Order is semantically meaningful: rules are evaluated in order under first-match combining (ADR-015). Each rule is a structurally slimmer constraint with principal, optional condition, and effect (and kind-specific extras such as transformation for ColumnVisibility)."""@en ;
    rdfs:domain tessera:Policy ;
    rdfs:range rdf:List .

tessera:defaultBranch a owl:ObjectProperty ;
    rdfs:label "default branch"@en ;
    rdfs:comment
        """The default branch of a Policy under defaultStrategy: negated-complement. Applies when no rule in `rules` matches. A slimmer rule (no principal selector; effect and optional condition only). Required iff defaultStrategy is tessera:negatedComplement; forbidden otherwise. See ADR-014."""@en ;
    rdfs:domain tessera:Policy .

# --- Resource classification ---

tessera:classification a owl:ObjectProperty ;
    rdfs:label "classification"@en ;
    rdfs:comment "Relates a Resource to a Classification it carries. A Resource may carry multiple classifications."@en ;
    rdfs:domain tessera:Resource ;
    rdfs:range tessera:Classification .

# --- Selector internals ---

tessera:selectorKind a owl:ObjectProperty ;
    rdfs:label "selector kind"@en ;
    rdfs:comment "Identifies the kind of a Selector (byIdentity, byClassification, byDataset, byScope, etc.)."@en ;
    rdfs:domain tessera:Selector .

tessera:resourceRef a owl:DatatypeProperty ;
    rdfs:label "resource reference"@en ;
    rdfs:comment "URI of a specific resource, used by byIdentity selectors."@en ;
    rdfs:range xsd:string .

# --- byScope selector and ABAC attribute matching (ADRs 019, 020) ---

tessera:scope a owl:DatatypeProperty ;
    rdfs:label "scope"@en ;
    rdfs:comment
        """The resource IRI at which a byScope selector attaches. The kind (catalog/schema/table/column) is inferred from the IRI's prefix per ADR-019."""@en ;
    rdfs:domain tessera:ResourceSelector ;
    rdfs:range xsd:string .

tessera:exceptFromScope a owl:DatatypeProperty ;
    rdfs:label "except from scope"@en ;
    rdfs:comment
        """Optional list of resource IRIs to exclude from a byScope selector's scope. Narrows the resource set; structurally distinct from principal exclusion. See ADR-019."""@en ;
    rdfs:domain tessera:ResourceSelector ;
    rdfs:range xsd:string .

tessera:matching a owl:ObjectProperty ;
    rdfs:label "matching"@en ;
    rdfs:comment
        """Optional attribute-matching expression on a byScope selector. Narrows which resources within the scope the policy applies to. Composes via the byComposition algebra (match: and|or|not, criteria: [...]) over AttributeMatcher leaves. See ADR-020."""@en ;
    rdfs:domain tessera:ResourceSelector .

tessera:AttributeMatcher a owl:Class ;
    rdfs:subClassOf tessera:Entity ;
    rdfs:label "Attribute matcher"@en ;
    rdfs:comment
        """A leaf in the matching expression. Names an attribute axis and a value; matches resources whose attribute on that axis is the named value (with hierarchical subsumption applied per axisType). See ADR-020."""@en .

tessera:axis a owl:ObjectProperty ;
    rdfs:label "axis"@en ;
    rdfs:comment "Relates an AttributeMatcher to the axis it tests against."@en ;
    rdfs:domain tessera:AttributeMatcher ;
    rdfs:range tessera:AttributeAxis .

tessera:axisValue a owl:ObjectProperty ;
    rdfs:label "axis value"@en ;
    rdfs:comment
        """Relates an AttributeMatcher to the value it tests for. For hierarchical axes, this is a class reference; for flat axes, a named individual."""@en ;
    rdfs:domain tessera:AttributeMatcher .

tessera:tableRef a owl:DatatypeProperty ;
    rdfs:label "table reference"@en ;
    rdfs:comment "Fully qualified name of the table backing a PrincipalSetFromTable or ResourceSetFromTable."@en ;
    rdfs:range xsd:string .

tessera:principalColumn a owl:DatatypeProperty ;
    rdfs:label "principal column"@en ;
    rdfs:domain tessera:PrincipalSetFromTable ;
    rdfs:range xsd:string .

tessera:resourceColumn a owl:DatatypeProperty ;
    rdfs:label "resource column"@en ;
    rdfs:range xsd:string .

tessera:permissionColumn a owl:DatatypeProperty ;
    rdfs:label "permission column"@en ;
    rdfs:range xsd:string .

tessera:permissionValue a owl:DatatypeProperty ;
    rdfs:label "permission value"@en ;
    rdfs:range xsd:string .

# --- Condition algebra ---

tessera:operator a owl:ObjectProperty ;
    rdfs:label "operator"@en ;
    rdfs:comment "Identifies the operator of a Condition (and, or, not, eq, in, purposeIn, etc.)."@en ;
    rdfs:domain tessera:Condition .

tessera:operands a rdf:Property ;
    rdfs:label "operands"@en ;
    rdfs:comment "Ordered list of operands for a Condition; structure depends on the operator."@en ;
    rdfs:domain tessera:Condition .

# --- Obligation parameters ---

tessera:obligationTarget a owl:DatatypeProperty ;
    rdfs:label "obligation target"@en ;
    rdfs:comment "URI or name identifying the destination of an obligation (audit log topic, notification target, etc.)."@en ;
    rdfs:domain tessera:Obligation ;
    rdfs:range xsd:string .

# --- Provenance ---

tessera:provenance a owl:ObjectProperty ;
    rdfs:label "provenance"@en ;
    rdfs:comment "Relates a policy to metadata about its origin (author, extraction source, confidence)."@en ;
    rdfs:domain tessera:PolicyConstraint .

tessera:extractedFrom a owl:DatatypeProperty ;
    rdfs:label "extracted from"@en ;
    rdfs:comment "URI identifying the platform and artifact a policy was extracted from."@en ;
    rdfs:range xsd:string .

tessera:extractedAt a owl:DatatypeProperty ;
    rdfs:label "extracted at"@en ;
    rdfs:range xsd:dateTime .

tessera:extractionConfidence a owl:ObjectProperty ;
    rdfs:label "extraction confidence"@en ;
    rdfs:range tessera:ExtractionConfidence .

tessera:originalConstruct a owl:DatatypeProperty ;
    rdfs:label "original construct"@en ;
    rdfs:comment "Verbatim representation of the source artifact, preserved for human review where extraction confidence is below High."@en ;
    rdfs:range xsd:string .

tessera:version a owl:DatatypeProperty ;
    rdfs:label "version"@en ;
    rdfs:comment "Semantic version of a policy instance."@en ;
    rdfs:range xsd:string .


#
# ============================================================================
# End of v0 ontology
# ============================================================================
# What this file does NOT yet contain, deliberately:
#   - SHACL shapes for validation beyond what JSON Schema captures.
#     These will live in spec/v0/shapes.ttl when written.
#   - Owl:equivalentClass declarations against DPV/ODRL/Cedar.
#     Alignment is documented as skos:exactMatch / skos:closeMatch where
#     correspondence is unambiguous; formal equivalence is deferred until
#     the corpus exposes whether tighter alignment causes friction.
#   - Cardinality constraints. OWL cardinality on policy structure would be
#     restrictive in ways the v0 corpus may not yet justify. JSON Schema
#     carries the necessary structural constraints in the interim.
#   - Disjointness axioms (e.g. owl:disjointWith between Allow and Deny).
#     Deferred until reasoning becomes part of the validation pipeline.
#
# These omissions are tracked. Revisions in subsequent ontology versions
# will follow the immutability rule: v0 is fixed once published; v1 is a
# new file at a parallel URL.
