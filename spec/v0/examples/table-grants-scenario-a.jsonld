{
  "@context": "https://bgiesbrecht.github.io/tessera/spec/v0/context.jsonld",
  "@type": "Policy",
  "@id": "policy:table-grants-scenario-a",
  "version": "1.0.0",
  "policyKind": "AccessGrantConstraint",
  "description": "Marketing analytics team can Read bg_rls_demo.tpch.orders.\nPurely affirmative; principals not in the group fall through to whatever\nother policies or platform defaults apply (defaultStrategy omitted).",
  "appliesTo": {
    "selector": "byIdentity",
    "resource": "table:bg_rls_demo.tpch.orders"
  },
  "action": "Read",
  "rules": [
    {
      "principal": {
        "selector": "byIdentity",
        "resource": "group:bg_rls_demo_marketing_analytics"
      },
      "effect": "allow"
    }
  ]
}
