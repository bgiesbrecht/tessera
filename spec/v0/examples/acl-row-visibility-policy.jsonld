{
  "@context": "https://bgiesbrecht.github.io/tessera/spec/v0/context.jsonld",
  "@type": "Policy",
  "@id": "policy:acl-row-visibility",
  "version": "1.0.0",
  "policyKind": "RowVisibilityConstraint",
  "description": "A principal sees rows of bg_rls_demo.tpch.orders_rls_acl whose o_orderpriority is granted to them via the two-table ACL join (rls_acl_mapping ⋈ rls_priority_acl on code_name). Principals not in the ACL mapping see no rows (fail-closed; defaultStrategy: none).",

  "appliesTo": {
    "selector": "byIdentity",
    "resource": "table:bg_rls_demo.tpch.orders_rls_acl"
  },

  "action": "Read",

  "defaultStrategy": "none",

  "rules": [
    {
      "principal": {
        "selector": "byDataset",
        "dataset": {
          "@type": "PrincipalSetFromTable",
          "table": "bg_rls_demo.tpch.rls_acl_mapping",
          "principalColumn": "username",
          "resourceColumn": "code_name"
        }
      },
      "condition": {
        "op": "exists-in-dataset",
        "operands": [
          {
            "@type": "ResourceSetFromTable",
            "table": "bg_rls_demo.tpch.rls_priority_acl",
            "principalColumn": "code_name",
            "resourceColumn": "orderpriority"
          }
        ]
      },
      "effect": "keep-matching-rows"
    }
  ],

  "capabilityRequirements": [
    "data-driven-selectors",
    "two-table-join-via-codename",
    "case-insensitive-principal-match",
    "fail-closed-on-acl-absence"
  ],

  "provenance": {
    "notes": "Hand-authored for the ACL-table worked example. The principal selector and condition are the closest v0 representation of a two-table join pattern. The actual SQL emission compiles the full join; the IR carries only the structural shape v0 can express. See diagnostic §4 for the gaps this exercise surfaces."
  }
}
