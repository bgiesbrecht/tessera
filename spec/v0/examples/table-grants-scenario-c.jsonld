{
  "@context": "https://bgiesbrecht.github.io/tessera/spec/v0/context.jsonld",
  "@type": "Policy",
  "@id": "policy:table-grants-scenario-c",
  "version": "1.0.0",
  "policyKind": "RowVisibilityConstraint",
  "description": "Marketing analytics team can Execute the compute_customer_ltv function. Semantic-policy use of EXECUTE; platform-mechanism uses (UDFs as policy-enforcement vehicles) are adapter scaffolding, not modeled in the IR.",

  "appliesTo": {
    "selector": "byIdentity",
    "resource": "function:bg_rls_demo.tpch.compute_customer_ltv"
  },

  "action": "Execute",

  "rules": [
    {
      "principal": {
        "selector": "byIdentity",
        "resource": "group:bg_rls_demo_marketing_analytics"
      },
      "effect": "allow"
    }
  ],

  "provenance": {
    "notes": "Scenario C of the table-grants exercise. First use of Execute action (added to v0 with semantic-only scope). First use of function: IRI prefix (new informal convention)."
  }
}
