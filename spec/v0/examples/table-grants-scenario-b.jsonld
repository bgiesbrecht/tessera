{
  "@context": "https://bgiesbrecht.github.io/tessera/spec/v0/context.jsonld",
  "@type": "Policy",
  "@id": "policy:table-grants-scenario-b",
  "version": "1.0.0",
  "policyKind": "AccessGrantConstraint",
  "description": "Data engineering team can Read every table in bg_rls_demo.tpch_staging,\nincluding tables added after the policy is applied. No explicit\nenumeration; byScope at schema level propagates downward.",
  "appliesTo": {
    "selector": "byScope",
    "scope": "schema:bg_rls_demo.tpch_staging"
  },
  "action": "Read",
  "rules": [
    {
      "principal": {
        "selector": "byIdentity",
        "resource": "group:bg_rls_demo_data_engineering"
      },
      "effect": "allow"
    }
  ]
}
