{
  "@context": "https://bgiesbrecht.github.io/tessera/spec/v0/context.jsonld",
  "@type": "Policy",
  "@id": "policy:snowflake-byDataset-row-visibility",
  "version": "1.0.0",
  "policyKind": "RowVisibilityConstraint",
  "description": "A principal sees rows of BRICETEST.TESSERA.SNOW_ORDERS_RLS_ACL whose O_ORDERPRIORITY is granted to them via the two-table ACL join (RLS_ACL_MAPPING ⋈ RLS_PRIORITY_ACL on CODE_NAME). Principals not in the ACL mapping see no rows (fail-closed; defaultStrategy: none). Snowflake counterpart to policy:acl-row-visibility; the IR shape is identical except for platform-bound table identifiers.",

  "appliesTo": {
    "selector": "byIdentity",
    "resource": "table:BRICETEST.TESSERA.SNOW_ORDERS_RLS_ACL"
  },

  "action": "Read",

  "defaultStrategy": "none",

  "rules": [
    {
      "principal": {
        "selector": "byDataset",
        "dataset": {
          "@type": "PrincipalSetFromTable",
          "table": "BRICETEST.TESSERA.RLS_ACL_MAPPING",
          "principalColumn": "USERNAME",
          "resourceColumn": "CODE_NAME"
        }
      },
      "condition": {
        "op": "exists-in-dataset",
        "operands": [
          {
            "@type": "ResourceSetFromTable",
            "table": "BRICETEST.TESSERA.RLS_PRIORITY_ACL",
            "principalColumn": "CODE_NAME",
            "resourceColumn": "O_ORDERPRIORITY"
          }
        ]
      },
      "effect": "keep-matching-rows"
    }
  ],

  "capabilityRequirements": [
    "data-driven-selectors",
    "two-table-join-via-codename",
    "fail-closed-on-acl-absence"
  ],

  "provenance": {
    "notes": "Snowflake counterpart to policy:acl-row-visibility. The IR is structurally identical to the Databricks ACL IR. Platform divergence lives entirely in the adapter's emission: Snowflake produces CREATE ROW ACCESS POLICY ... -> EXISTS(...) where Databricks produced CREATE FUNCTION ... AS FILTER ... EXISTS(...). The lack of a case-insensitive-principal-match capability requirement (present in the Databricks counterpart) reflects Snowflake's identifier folding handling the case-normalization case structurally."
  }
}
