{
  "@context": "https://bgiesbrecht.github.io/tessera/spec/v0/context.jsonld",
  "@type": "Policy",
  "@id": "policy:abac-column-mask-clerk-hash",
  "version": "1.0.0",
  "policyKind": "ColumnVisibilityConstraint",
  "description": "ABAC column-mask policy attached at catalog scope. Matches the same PIIClerk-tagged columns as Policy A; replaces values with their SHA-256 hash for principals outside bg_rls_demo_all_priority_ops.",

  "appliesTo": {
    "selector": "byScope",
    "scope": "catalog:bg_rls_demo",
    "matching": {
      "attributes": {
        "sensitivity": "PIIClerk"
      }
    }
  },

  "action": "Read",

  "defaultStrategy": "negated-complement",

  "rules": [
    {
      "principal": {
        "selector": "byIdentity",
        "resource": "group:bg_rls_demo_all_priority_ops"
      },
      "effect": "allow"
    }
  ],

  "defaultBranch": {
    "effect": "transform",
    "transformation": {
      "type": "Hash",
      "algorithm": "sha256"
    }
  },

  "capabilityRequirements": [
    "scoped-policy-attachment",
    "attribute-axis-matching",
    "tag-taxonomy-mapping"
  ],

  "provenance": {
    "notes": "Hand-authored as the companion to Policy A. The deliberate same-matcher / different-transformation overlap is the design Stage 3 uses to surface ADR-019's deferred cross-policy combination decision (α/β/γ)."
  }
}
