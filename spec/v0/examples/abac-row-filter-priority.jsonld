{
  "@context": "https://bgiesbrecht.github.io/tessera/spec/v0/context.jsonld",
  "@type": "Policy",
  "@id": "policy:abac-row-filter-priority",
  "version": "1.0.0",
  "policyKind": "RowVisibilityConstraint",
  "description": "Three-branch row visibility on tables in acme whose o_orderpriority column is tagged for ABAC row filtering. Members of acme_all_priority_ops see all rows; members of acme_high_priority_ops see priority 1-URGENT and 2-HIGH only; everyone else sees priority 3-MEDIUM, 4-NOT SPECIFIED, 5-LOW.",
  "appliesTo": {
    "selector": "byScope",
    "scope": "catalog:acme",
    "matching": {
      "attributes": {
        "acme:rowDiscriminator": "orderpriority"
      }
    }
  },
  "action": "Read",
  "defaultStrategy": "negated-complement",
  "rules": [
    {
      "principal": {
        "selector": "byIdentity",
        "resource": "group:acme_all_priority_ops"
      },
      "effect": "keep-matching-rows"
    },
    {
      "principal": {
        "selector": "byIdentity",
        "resource": "group:acme_high_priority_ops"
      },
      "effect": "keep-matching-rows",
      "condition": {
        "op": "in",
        "operands": [
          "column:$matched"
        ],
        "values": [
          "1-URGENT",
          "2-HIGH"
        ]
      }
    }
  ],
  "defaultBranch": {
    "effect": "keep-matching-rows",
    "condition": {
      "op": "in",
      "operands": [
        "column:$matched"
      ],
      "values": [
        "3-MEDIUM",
        "4-NOT SPECIFIED",
        "5-LOW"
      ]
    }
  },
  "capabilityRequirements": [
    "scoped-policy-attachment",
    "attribute-axis-matching",
    "tag-taxonomy-mapping",
    "matched-column-reference"
  ],
  "provenance": {
    "notes": "Hand-authored for the ABAC RLS exercise. Blind derivation from\ndocs/exercises/abac-row-filter-priority-inputs.md; Brice's existing\nimplementation has not been shared. Phase 3 comparison happens\nafter Phase 2 commits."
  }
}
