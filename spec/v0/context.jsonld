{
  "@context": {
    "@version": 1.1,
    "@protected": true,

    "_comment_header": "Tessera context v0. Immutable once published. Defines the short names used in Tessera policy documents and maps them to their full IRIs. The ontology proper is published separately as Turtle/OWL at https://bgiesbrecht.github.io/tessera/spec/v0/ontology.ttl. See DECISIONS.md ADR-004 and ADR-005 for the rationale behind this document.",

    "tessera": "https://bgiesbrecht.github.io/tessera/spec/v0/vocab#",
    "dpv": "https://w3id.org/dpv#",
    "odrl": "http://www.w3.org/ns/odrl/2/",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "_comment_core_classes": "Core entity classes — see technical design v0.2 §3.1",

    "Principal":              "tessera:Principal",
    "User":                   "tessera:User",
    "Group":                  "tessera:Group",
    "ServiceAccount":         "tessera:ServiceAccount",
    "Role":                   "tessera:Role",

    "Resource":               "tessera:Resource",
    "DataProduct":            "tessera:DataProduct",
    "Schema":                 "tessera:Schema",
    "Table":                  "tessera:Table",
    "View":                   "tessera:View",
    "Column":                 "tessera:Column",
    "RowSet":                 "tessera:RowSet",

    "Action":                 "tessera:Action",
    "Classification":         "tessera:Classification",
    "Purpose": {
      "@id": "dpv:Purpose",
      "_comment": "Reused from DPV per ADR-005; Tessera-specific purposes use the tessera: namespace and declare dpv:Purpose as their parent class in the ontology."
    },
    "Jurisdiction":           "tessera:Jurisdiction",
    "Condition":              "tessera:Condition",
    "Obligation":             "tessera:Obligation",
    "Transformation":         "tessera:Transformation",

    "_comment_policy_classes": "Policy entity classes — named by what they constrain, not by mechanism (see technical design v0.2 §3.2)",

    "AccessConstraint":           "tessera:AccessConstraint",
    "RowVisibilityConstraint":    "tessera:RowVisibilityConstraint",
    "ColumnVisibilityConstraint": "tessera:ColumnVisibilityConstraint",
    "DistributionConstraint":     "tessera:DistributionConstraint",

    "_comment_policy_container": "Policy is the multi-rule container class introduced in ADR-014. See technical design v0.2 §4.2.",

    "Policy":                     "tessera:Policy",

    "_comment_selector_classes": "Selector classes — see technical design v0.2 §3.3",

    "PrincipalSelector":       "tessera:PrincipalSelector",
    "ResourceSelector":        "tessera:ResourceSelector",
    "PrincipalSetFromTable":   "tessera:PrincipalSetFromTable",
    "ResourceSetFromTable":    "tessera:ResourceSetFromTable",

    "_comment_obligation_classes": "Obligation classes — extensible per adapter capability",

    "AuditLog":             "tessera:AuditLog",
    "Notify":               "tessera:Notify",
    "Watermark":            "tessera:Watermark",

    "_comment_transformation_classes": "Transformation classes — closed vocabulary in v0; new transformations require spec extension to preserve portability. Per ADR-016, transformations are referenced as structured TransformationInstance objects with parameter fields.",

    "Mask":                 "tessera:Mask",
    "Hash":                 "tessera:Hash",
    "Tokenize":             "tessera:Tokenize",
    "Redact":               "tessera:Redact",
    "Bucketize":            "tessera:Bucketize",
    "TransformationInstance": "tessera:TransformationInstance",

    "_comment_transformation_parameters": "Parameter properties on TransformationInstance — see ADR-016 for per-transformation parameter shapes",

    "replacement": {
      "@id": "tessera:replacement"
    },
    "maskChar": {
      "@id": "tessera:maskChar",
      "@type": "xsd:string"
    },
    "preserveFirst": {
      "@id": "tessera:preserveFirst",
      "@type": "xsd:nonNegativeInteger"
    },
    "preserveLast": {
      "@id": "tessera:preserveLast",
      "@type": "xsd:nonNegativeInteger"
    },
    "algorithm": {
      "@id": "tessera:algorithm",
      "@type": "xsd:string"
    },

    "_comment_policy_properties": "Properties used on policy documents",

    "version": {
      "@id": "tessera:version",
      "@type": "xsd:string"
    },
    "description": {
      "@id": "rdfs:comment",
      "@type": "xsd:string"
    },
    "appliesTo": {
      "@id": "tessera:appliesTo",
      "@type": "@id"
    },
    "principal": {
      "@id": "tessera:principal",
      "@type": "@id"
    },
    "action": {
      "@id": "tessera:action",
      "@type": "@vocab"
    },
    "effect": {
      "@id": "tessera:effect",
      "@type": "@vocab"
    },
    "condition": {
      "@id": "tessera:condition",
      "@type": "@id"
    },
    "transformation": {
      "@id": "tessera:transformation",
      "@type": "@id"
    },
    "obligations": {
      "@id": "tessera:hasObligation",
      "@type": "@id",
      "@container": "@set"
    },
    "capabilityRequirements": {
      "@id": "tessera:requiresCapability",
      "@type": "xsd:string",
      "@container": "@set"
    },
    "defaultStrategy": {
      "@id": "tessera:defaultStrategy",
      "@type": "@vocab"
    },
    "baselineGroup": {
      "@id": "tessera:baselineGroup",
      "@type": "xsd:string"
    },
    "policyKind": {
      "@id": "tessera:policyKind",
      "@type": "@vocab",
      "_comment": "Discriminator selecting the policy domain. Values are the existing PolicyConstraint subclass short names (RowVisibilityConstraint, AccessConstraint, etc.). See ADR-014."
    },
    "rules": {
      "@id": "tessera:rules",
      "@container": "@list",
      "_comment": "Ordered list of rules in a Policy. Order is semantically meaningful (first-match combining, ADR-015)."
    },
    "defaultBranch": {
      "@id": "tessera:defaultBranch",
      "@type": "@id",
      "_comment": "Default branch under defaultStrategy: negated-complement. Required iff that strategy; forbidden otherwise. See ADR-014."
    },
    "provenance": {
      "@id": "tessera:provenance",
      "@type": "@id"
    },

    "_comment_selector_properties": "Properties used on selector documents",

    "selector": {
      "@id": "tessera:selectorKind",
      "@type": "@vocab"
    },
    "resource": {
      "@id": "tessera:resourceRef",
      "@type": "@id"
    },
    "dataset": {
      "@id": "tessera:dataset",
      "@type": "@id"
    },
    "table": {
      "@id": "tessera:tableRef",
      "@type": "xsd:string"
    },
    "principalColumn": {
      "@id": "tessera:principalColumn",
      "@type": "xsd:string"
    },
    "resourceColumn": {
      "@id": "tessera:resourceColumn",
      "@type": "xsd:string"
    },
    "permissionColumn": {
      "@id": "tessera:permissionColumn",
      "@type": "xsd:string"
    },
    "permissionValue": {
      "@id": "tessera:permissionValue",
      "@type": "xsd:string"
    },
    "criteria": {
      "@id": "tessera:criteria",
      "@container": "@set"
    },
    "match": {
      "@id": "tessera:matchKind",
      "@type": "@vocab"
    },

    "_comment_classification_properties": "Classification hierarchy uses rdfs:subClassOf in the ontology; documents reference classifications by IRI",

    "classification": {
      "@id": "tessera:classification",
      "@type": "@id"
    },
    "locatedIn": {
      "@id": "tessera:locatedIn",
      "@type": "@id"
    },

    "_comment_condition_properties": "Condition algebra — fixed set of constructors, see technical design v0.2 §4.4",

    "op": {
      "@id": "tessera:operator",
      "@type": "@vocab"
    },
    "operands": {
      "@id": "tessera:operands",
      "@container": "@list"
    },
    "values": {
      "@id": "tessera:operandValues",
      "@container": "@list"
    },

    "_comment_obligation_properties": "Obligation parameters",

    "target": {
      "@id": "tessera:obligationTarget",
      "@type": "xsd:string"
    },

    "_comment_provenance_properties": "Provenance metadata, especially important for extracted policies",

    "extractedFrom": {
      "@id": "tessera:extractedFrom",
      "@type": "xsd:string"
    },
    "extractedAt": {
      "@id": "tessera:extractedAt",
      "@type": "xsd:dateTime"
    },
    "confidence": {
      "@id": "tessera:extractionConfidence",
      "@type": "@vocab"
    },
    "notes": {
      "@id": "rdfs:comment",
      "@type": "xsd:string"
    },
    "originalConstruct": {
      "@id": "tessera:originalConstruct",
      "@type": "xsd:string"
    },

    "_comment_well_known_classifications": "Initial well-known classifications. Organizations extend with their own under their own namespaces. Privacy-related classifications align with DPV.",

    "PII":              { "@id": "tessera:PII", "_comment": "Personally Identifiable Information; superclass for PHI, Financial.Personal, etc." },
    "PHI":              "tessera:PHI",
    "Financial":        "tessera:Financial",
    "Public":           "tessera:Public",
    "Confidential":     "tessera:Confidential",
    "Restricted":       "tessera:Restricted",

    "_comment_well_known_purposes": "Initial well-known purposes. Aligned with DPV; organizations extend.",

    "Analytics":            "tessera:Analytics",
    "Operations":           "tessera:Operations",
    "FraudInvestigation":   "tessera:FraudInvestigation",
    "Audit":                "tessera:Audit",
    "Compliance":           "tessera:Compliance",
    "Marketing":            "tessera:Marketing",

    "_comment_well_known_actions": "Initial action vocabulary; ADR-007 tracks the extensibility question",

    "Read":      "tessera:Read",
    "Write":     "tessera:Write",
    "Delete":    "tessera:Delete",
    "Share":     "tessera:Share",
    "Sample":    "tessera:Sample",
    "Aggregate": "tessera:Aggregate",

    "_comment_well_known_effects": "Effects a policy may declare",

    "allow":               "tessera:allow",
    "deny":                "tessera:deny",
    "transform":           "tessera:transform",
    "keep-matching-rows":  "tessera:keepMatchingRows",
    "drop-matching-rows":  "tessera:dropMatchingRows",

    "_comment_well_known_default_strategies": "Default-handling strategies for policies with multiple branches — see ADR-013",

    "explicit-baseline-group": "tessera:explicitBaselineGroup",
    "negated-complement":      "tessera:negatedComplement",
    "none":                    "tessera:none",

    "_comment_well_known_selector_kinds": "Selector kinds — see technical design v0.2 §3.3",

    "byIdentity":        "tessera:byIdentity",
    "byAttribute":       "tessera:byAttribute",
    "byClassification":  "tessera:byClassification",
    "byDataset":         "tessera:byDataset",
    "byComposition":     "tessera:byComposition",

    "_comment_well_known_condition_operators": "Condition algebra operators",

    "and":            "tessera:and",
    "or":             "tessera:or",
    "not":            "tessera:not",
    "eq":             "tessera:eq",
    "lt":             "tessera:lt",
    "gt":             "tessera:gt",
    "in":             "tessera:in",
    "purpose-in":     "tessera:purposeIn",
    "located-in":     "tessera:locatedIn",
    "time-window":    "tessera:timeWindow",
    "consent-granted":"tessera:consentGranted",
    "exists-in-dataset": "tessera:existsInDataset",

    "_comment_confidence_levels": "Extraction confidence levels — see technical design v0.2 §4.3",

    "high":   "tessera:confidenceHigh",
    "medium": "tessera:confidenceMedium",
    "low":    "tessera:confidenceLow"
  }
}
